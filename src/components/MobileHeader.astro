---
import LogoBlack from "../assets/logo-black.svg";
---

<header
  class="bg-background/95 border-border fixed top-0 right-0 left-0 z-50 border-b px-6 py-4 backdrop-blur-sm lg:hidden"
>
  <div class="flex items-center justify-between">
    <a href="/" aria-label="Accueil">
      <LogoBlack class="h-8 w-auto" aria-label="fideloc" role="img" />
    </a>
    <button
      id="mobile-menu-toggle"
      class="text-foreground p-2"
      aria-label="Menu"
    >
      <svg
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
      >
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
    </button>
  </div>
</header>
