---
import { stegaClean } from "@sanity/client/stega";
import LogoWhite from "../assets/logo-white.svg";

interface Props {
  intro?: string | null;
  headlineLine1?: string | null;
  headlineLine2?: string | null;
  secondParagraph?: string | null;
  badge?: string | null;
  ctaLabel?: string | null;
}

const {
  intro,
  headlineLine1,
  headlineLine2,
  secondParagraph,
  badge,
  ctaLabel,
} = Astro.props;

const cleanIntro = stegaClean(intro ?? "");
const cleanHeadlineLine1 = stegaClean(headlineLine1 ?? "");
const cleanHeadlineLine2 = stegaClean(headlineLine2 ?? "");
const cleanSecondParagraph = stegaClean(secondParagraph ?? "");
const cleanBadge = stegaClean(badge ?? "");
const cleanCtaLabel = stegaClean(ctaLabel ?? "");
---

<section
  class="from-primary via-primary relative mt-14 overflow-hidden bg-linear-to-br to-[#0f1a2e] py-16 md:py-24"
>
  <div
    class="relative z-10 mx-auto grid max-w-7xl gap-10 px-4 md:grid-cols-5 md:px-8"
  >
    <div class="md:col-span-3">
      <h2
        class="font-heading text-3xl leading-tight font-bold text-white md:text-4xl"
      >
        {cleanHeadlineLine1}
        {cleanHeadlineLine2 && <br />}
        {cleanHeadlineLine2}
      </h2>
      <div
        class="mt-6 max-w-lg space-y-4 text-sm leading-relaxed text-white/60"
      >
        {cleanIntro && <p>{cleanIntro}</p>}
        {cleanSecondParagraph && <p>{cleanSecondParagraph}</p>}
      </div>
      {
        cleanCtaLabel && (
          <a
            href="/a-propos"
            class="mt-6 inline-flex items-center gap-2 rounded-(--radius) border border-white/20 px-5 py-2.5 text-sm font-medium text-white transition-colors hover:bg-white/10"
          >
            {cleanCtaLabel}
          </a>
        )
      }
    </div>

    <div class="flex items-center md:col-span-2">
      <div
        class="bg-background/[0.06] w-full rounded-xl border border-white/10 px-8 py-10 text-center backdrop-blur-sm"
      >
        {
          cleanBadge && (
            <p class="text-xs font-medium tracking-wider text-white/40">
              {cleanBadge}
            </p>
          )
        }
        <div class="mt-3">
          <LogoWhite class="mx-auto h-8 w-auto opacity-80" />
        </div>
      </div>
    </div>
  </div>
</section>
