---
interface Props {
  name: string;
  slug: string;
  description?: string | null;
  imageUrl?: string | null;
}

const { name, slug, description, imageUrl } = Astro.props;
---

<a href={`/produits/${slug}`} class="group block">
  <div class="bg-secondary/50 relative aspect-4/3 overflow-hidden rounded-xl">
    {
      imageUrl ? (
        <img
          src={imageUrl}
          alt={name}
          loading="lazy"
          class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 ease-out group-hover:scale-105"
        />
      ) : (
        <div class="bg-muted absolute inset-0" />
      )
    }
  </div>
  <h3
    class="font-heading text-primary group-hover:text-brand-accent mt-3 text-[15px] font-semibold transition-colors"
  >
    {name}
  </h3>
  {
    description && (
      <p class="text-muted-foreground mt-1 line-clamp-2 text-sm leading-snug">
        {description}
      </p>
    )
  }
</a>
