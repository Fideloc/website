---
export const prerender = false;

import Layout from "../layouts/Layout.astro";
import { getSiteSettings, getAllCategories } from "../lib/sanity";
import ContactForm from "../components/ContactForm";

const settings = await getSiteSettings();
const categories = await getAllCategories();
---

<Layout title="Contact — Fidéloc">
  <section class="mx-auto max-w-3xl px-6 py-16">
    <h1 class="font-heading text-primary text-4xl font-bold tracking-tight">
      Contactez-nous
    </h1>
    <p class="text-muted-foreground mt-2">
      Pour toute demande de devis ou d'information.
    </p>

    <div class="mt-10 space-y-4">
      {
        settings?.phone && (
          <div>
            <p class="text-sm font-medium">Téléphone</p>
            <a
              href={`tel:${settings.phone}`}
              class="text-brand-accent hover:underline"
            >
              {settings.phone}
            </a>
          </div>
        )
      }
      {
        settings?.email && (
          <div>
            <p class="text-sm font-medium">Email</p>
            <a
              href={`mailto:${settings.email}`}
              class="text-brand-accent hover:underline"
            >
              {settings.email}
            </a>
          </div>
        )
      }
      {
        settings?.serviceArea && (
          <div>
            <p class="text-sm font-medium">Zone de service</p>
            <p class="text-muted-foreground">{settings.serviceArea}</p>
          </div>
        )
      }
    </div>

    <div class="mt-12">
      <h2 class="font-heading text-primary mb-6 text-2xl font-semibold">
        Demande de réservation
      </h2>
      <ContactForm
        client:load
        categories={categories.map((c) => ({
          name: c.name ?? "",
          slug: c.slug ?? "",
        }))}
      />
    </div>
  </section>
</Layout>
