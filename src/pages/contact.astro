---
export const prerender = false;

import Layout from "../layouts/Layout.astro";
import {
  getSiteSettings,
  getAllCategories,
  getPageBySlug,
} from "../lib/sanity";
import ContactForm from "../components/ContactForm";
import { stegaClean } from "@sanity/client/stega";

const { data: settings } = await getSiteSettings();
const { data: categories } = await getAllCategories();
const { data: page } = await getPageBySlug("contact");
---

<Layout title={page?.title ? `${page.title} - Fidéloc` : ""}>
  <section class="mx-auto max-w-3xl px-6 py-16">
    <h1 class="font-heading text-primary text-4xl font-bold tracking-tight">
      {stegaClean(page?.title ?? "")}
    </h1>
    <p class="text-muted-foreground mt-2">
      {stegaClean(page?.intro ?? "")}
    </p>

    <div class="mt-10 space-y-4">
      {
        settings?.phone && (
          <div>
            <p class="text-sm font-medium">
              {stegaClean(page?.labels?.phoneLabel ?? "")}
            </p>
            <a
              href={`tel:${settings.phone}`}
              class="text-brand-accent hover:underline"
            >
              {settings.phone}
            </a>
          </div>
        )
      }
      {
        settings?.email && (
          <div>
            <p class="text-sm font-medium">
              {stegaClean(page?.labels?.emailLabel ?? "")}
            </p>
            <a
              href={`mailto:${settings.email}`}
              class="text-brand-accent hover:underline"
            >
              {settings.email}
            </a>
          </div>
        )
      }
      {
        settings?.serviceArea && (
          <div>
            <p class="text-sm font-medium">
              {stegaClean(page?.labels?.serviceAreaLabel ?? "")}
            </p>
            <p class="text-muted-foreground">{settings.serviceArea}</p>
          </div>
        )
      }
    </div>

    <div class="mt-12">
      <h2 class="font-heading text-primary mb-6 text-2xl font-semibold">
        {stegaClean(page?.labels?.reservationTitle ?? "")}
      </h2>
      <ContactForm
        client:load
        categories={categories.map((c) => ({
          name: c.name ?? "",
          slug: c.slug ?? "",
        }))}
      />
    </div>
  </section>
</Layout>
