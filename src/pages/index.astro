---
import Layout from "../layouts/Layout.astro";
import { getSiteSettings, getAllCategories } from "../lib/sanity";

const settings = await getSiteSettings();
const categories = await getAllCategories();
---

<Layout
  title={settings?.companyName
    ? `${settings.companyName} — Location d'équipement`
    : "Fidéloc"}
>
  <section class="mx-auto max-w-4xl px-6 py-16">
    <h1 class="font-heading text-primary text-5xl font-bold tracking-tight">
      {settings?.companyName ?? "Fidéloc"}
    </h1>
    {
      settings?.slogan && (
        <p class="text-muted-foreground mt-4 text-xl">{settings.slogan}</p>
      )
    }
    {
      settings?.heroCta && (
        <a
          href="/contact"
          class="bg-brand-accent mt-8 inline-block rounded-lg px-6 py-3 font-medium text-white"
        >
          {settings.heroCta}
        </a>
      )
    }
  </section>

  <section class="mx-auto max-w-4xl px-6 pb-16">
    <h2 class="font-heading text-primary mb-8 text-2xl font-semibold">
      Nos catégories
    </h2>
    {
      categories && categories.length > 0 ? (
        <ul class="grid gap-4 sm:grid-cols-2 md:grid-cols-3">
          {categories.map((cat) => (
            <li>
              <a
                href={`/produits/${cat.slug}`}
                class="border-border hover:border-brand-accent block rounded-lg border p-4 transition-colors"
              >
                <p class="font-heading text-primary font-semibold">
                  {cat.name}
                </p>
                {cat.description && (
                  <p class="text-muted-foreground mt-1 text-sm">
                    {cat.description}
                  </p>
                )}
              </a>
            </li>
          ))}
        </ul>
      ) : (
        <p class="text-muted-foreground">Aucune catégorie pour le moment.</p>
      )
    }
  </section>
</Layout>
