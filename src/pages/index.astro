---
import Layout from "../layouts/Layout.astro";
import {
  getSiteSettings,
  getAllCategories,
  getPageBySlug,
  urlFor,
} from "../lib/sanity";
import Hero from "../components/Hero";
import CategoryCarousel from "../components/CategoryCarousel";
import { stegaClean } from "@sanity/client/stega";

const { data: settings } = await getSiteSettings();
const { data: categories } = await getAllCategories();
const { data: homePage } = await getPageBySlug("accueil");

const carouselCategories = (categories ?? [])
  .filter((cat): cat is typeof cat & { name: string; slug: string } =>
    Boolean(cat.name && cat.slug),
  )
  .map((cat) => ({
    name: cat.name,
    slug: cat.slug,
    description: cat.description,
    imageUrl: cat.image?.asset
      ? urlFor(cat.image)
          .width(720)
          .height(540)
          .fit("crop")
          .auto("format")
          .url()
      : null,
  }));
---

<Layout
  title={settings?.companyName
    ? `${settings.companyName} - Location d'équipement`
    : "Fidéloc"}
>
  <div class="mx-auto max-w-5xl space-y-16 px-6 py-16">
    <Hero
      headline={stegaClean(settings?.heroHeadline ?? "")}
      headlineAccent={stegaClean(settings?.heroHeadlineAccent ?? "")}
      description={stegaClean(settings?.heroDescription ?? "")}
      primaryCta={stegaClean(settings?.heroPrimaryCta ?? "")}
      secondaryCta={stegaClean(settings?.heroSecondaryCta ?? "")}
    />

    <section>
      <h2 class="font-heading text-primary mb-6 text-2xl font-semibold">
        {stegaClean(homePage?.labels?.sectionTitle ?? "")}
      </h2>
      <CategoryCarousel categories={carouselCategories} client:visible />
    </section>
  </div>
</Layout>
