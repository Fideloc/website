---
import Layout from "../layouts/Layout.astro";
import { stegaClean } from "@sanity/client/stega";
import {
  getSiteSettings,
  getAllCategories,
  getPageBySlug,
  urlFor,
} from "../lib/sanity";
import HeroSection from "../components/HeroSection.astro";
import CategoriesSection from "../components/CategoriesSection.astro";
import QuoteCta from "../components/QuoteCta.astro";
import AboutSection from "../components/AboutSection.astro";
import HowItWorksSection from "../components/HowItWorksSection.astro";

const { data: settings } = await getSiteSettings();
const { data: categories } = await getAllCategories();
const { data: homePage } = await getPageBySlug("accueil");
const { data: aboutPage } = await getPageBySlug("a-propos");

const companyName = stegaClean(settings?.companyName ?? "");

const homeLabels = homePage?.labels;
const categoriesSectionTitle = stegaClean(homeLabels?.sectionTitle ?? "");
const categoriesViewAllLabel = stegaClean(
  homeLabels?.categoriesViewAllLabel ?? "",
);
const quoteCtaBadge = stegaClean(homeLabels?.quoteCtaBadge ?? "");
const quoteCtaHeadlineLine1 = stegaClean(
  homeLabels?.quoteCtaHeadlineLine1 ?? "",
);
const quoteCtaHeadlineLine2 = stegaClean(
  homeLabels?.quoteCtaHeadlineLine2 ?? "",
);
const quoteCtaDescription = stegaClean(homeLabels?.quoteCtaDescription ?? "");
const quoteCtaButtonLabel = stegaClean(homeLabels?.quoteCtaButtonLabel ?? "");
const deliveryFeeLabel = stegaClean(settings?.deliveryFeeLabel ?? "");
const deliveryFeeText = stegaClean(settings?.deliveryFeeText ?? "");
const aboutIntro = stegaClean(aboutPage?.intro ?? "");
const aboutHeadlineLine1 = stegaClean(
  homeLabels?.aboutTeaserHeadlineLine1 ?? "",
);
const aboutHeadlineLine2 = stegaClean(
  homeLabels?.aboutTeaserHeadlineLine2 ?? "",
);
const aboutSecondParagraph = stegaClean(
  homeLabels?.aboutTeaserSecondParagraph ?? "",
);
const aboutBadge = stegaClean(homeLabels?.aboutTeaserBadge ?? "");
const aboutCtaLabel = stegaClean(homeLabels?.aboutTeaserCtaLabel ?? "");
const howItWorksTitle = stegaClean(settings?.howItWorksTitle ?? "");
const howItWorksContactLabel = stegaClean(
  settings?.howItWorksContactLabel ?? "",
);
const howItWorksSteps = settings?.howItWorksSteps ?? [];

const categoryCards = (categories ?? [])
  .filter((cat): cat is typeof cat & { name: string; slug: string } =>
    Boolean(cat.name && cat.slug),
  )
  .map((cat) => ({
    name: cat.name,
    slug: cat.slug,
    description: cat.description,
    imageUrl: cat.image?.asset
      ? urlFor(cat.image)
          .width(600)
          .height(450)
          .fit("crop")
          .auto("format")
          .url()
      : null,
  }));
---

<Layout
  title={companyName ? `${companyName} - Location d'equipement` : "Fideloc"}
>
  <HeroSection settings={settings} />
  <CategoriesSection
    sectionTitle={categoriesSectionTitle}
    viewAllLabel={categoriesViewAllLabel}
    categories={categoryCards}
  />
  <QuoteCta
    badge={quoteCtaBadge}
    headlineLine1={quoteCtaHeadlineLine1}
    headlineLine2={quoteCtaHeadlineLine2}
    description={quoteCtaDescription}
    buttonLabel={quoteCtaButtonLabel}
    deliveryFeeLabel={deliveryFeeLabel}
    deliveryFeeText={deliveryFeeText}
  />
  <AboutSection
    intro={aboutIntro}
    headlineLine1={aboutHeadlineLine1}
    headlineLine2={aboutHeadlineLine2}
    secondParagraph={aboutSecondParagraph}
    badge={aboutBadge}
    ctaLabel={aboutCtaLabel}
  />
  <HowItWorksSection
    title={howItWorksTitle}
    contactLabel={howItWorksContactLabel}
    steps={howItWorksSteps}
  />
</Layout>
