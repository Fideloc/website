---
import Layout from "../layouts/Layout.astro";
import {
  getSiteSettings,
  getAllCategories,
  getPageBySlug,
  urlFor,
} from "../lib/sanity";
import HeroSection from "../components/HeroSection.astro";
import CategoriesSection from "../components/CategoriesSection.astro";
import QuoteCta from "../components/QuoteCta.astro";
import AboutSection from "../components/AboutSection.astro";
import HowItWorksSection from "../components/HowItWorksSection.astro";

const { data: settings } = await getSiteSettings();
const { data: categories } = await getAllCategories();
const { data: homePage } = await getPageBySlug("accueil");
const { data: aboutPage } = await getPageBySlug("a-propos");

const categoryCards = (categories ?? [])
  .filter((cat): cat is typeof cat & { name: string; slug: string } =>
    Boolean(cat.name && cat.slug),
  )
  .map((cat) => ({
    name: cat.name,
    slug: cat.slug,
    description: cat.description,
    imageUrl: cat.image?.asset
      ? urlFor(cat.image)
          .width(600)
          .height(450)
          .fit("crop")
          .auto("format")
          .url()
      : null,
  }));
---

<Layout
  title={settings?.companyName
    ? `${settings.companyName} - Location d'equipement`
    : "Fideloc"}
>
  <HeroSection settings={settings} />
  <CategoriesSection
    sectionTitle={homePage?.labels?.sectionTitle}
    categories={categoryCards}
  />
  <QuoteCta />
  <AboutSection intro={aboutPage?.intro} />
  <HowItWorksSection />
</Layout>
