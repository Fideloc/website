---
import Layout from "../layouts/Layout.astro";
import { PortableText } from "astro-portabletext";
import { getPageBySlug } from "../lib/sanity";

const page = await getPageBySlug("mentions-legales");
---

<Layout
  title={page?.title ? `${page.title} — Fidéloc` : "Mentions légales — Fidéloc"}
>
  <section class="mx-auto max-w-3xl px-6 py-16">
    <h1 class="font-heading text-primary text-4xl font-bold tracking-tight">
      {page?.title ?? "Mentions légales"}
    </h1>
    {
      page?.content ? (
        <div class="prose mt-8 max-w-none">
          <PortableText value={page.content} />
        </div>
      ) : (
        <p class="text-muted-foreground mt-8">Contenu à venir.</p>
      )
    }
  </section>
</Layout>
