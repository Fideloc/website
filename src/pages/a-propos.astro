---
import Layout from "../layouts/Layout.astro";
import { PortableText } from "astro-portabletext";
import { getPageBySlug } from "../lib/sanity";

const { data: page } = await getPageBySlug("a-propos");
---

<Layout title={page?.title ? `${page.title} - Fidéloc` : ""}>
  <section class="mx-auto max-w-7xl px-4 py-16 md:px-8">
    <h1 class="font-heading text-primary text-4xl font-bold tracking-tight">
      {page?.title ?? ""}
    </h1>
    {
      page?.content ? (
        <div class="prose mt-8 max-w-none">
          <PortableText value={page.content} />
        </div>
      ) : (
        <p class="text-muted-foreground mt-8" />
      )
    }
  </section>
</Layout>
