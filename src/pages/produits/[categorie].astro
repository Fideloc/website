---
import Layout from "../../layouts/Layout.astro";
import ProductCard from "../../components/ProductCard.astro";
import {
  getAllCategories,
  getCategoryBySlug,
  getPageBySlug,
  getProductsByCategory,
} from "../../lib/sanity";
import { stegaClean } from "@sanity/client/stega";

export async function getStaticPaths() {
  const { data: categories } = await getAllCategories();
  return (categories ?? []).map((cat) => ({
    params: { categorie: cat.slug },
  }));
}

const { categorie } = Astro.params;
const { data: category } = await getCategoryBySlug(categorie!);
const { data: categoryTemplatePage } =
  await getPageBySlug("produits-categorie");

if (!category) {
  return Astro.redirect("/produits");
}

const { data: products } = await getProductsByCategory(category._id);

const labels = categoryTemplatePage?.labels;
const capacityUnit = stegaClean(labels?.capacityUnit ?? "");
const priceWeekendShortSuffix = stegaClean(
  labels?.priceWeekendShortSuffix ?? "",
);
const priceWeekShortSuffix = stegaClean(labels?.priceWeekShortSuffix ?? "");
const emptyState = stegaClean(labels?.emptyState ?? "");

const categoryName = stegaClean(category.name ?? "");
const categoryDescription = stegaClean(category.description ?? "");
---

<Layout title={`${categoryName} - Fidéloc`}>
  <section class="mx-auto max-w-7xl px-4 py-16 md:px-8">
    <!-- Breadcrumb -->
    <nav class="text-muted-foreground mb-8 text-sm">
      <a href="/produits" class="text-brand-accent hover:underline">
        {stegaClean(categoryTemplatePage?.labels?.breadcrumbCatalogLabel ?? "")}
      </a>
      <span class="mx-2">/</span>
      <span>{categoryName}</span>
    </nav>
    <h1 class="font-heading text-primary text-4xl font-bold tracking-tight">
      {categoryName}
    </h1>
    {
      categoryDescription && (
        <p class="text-muted-foreground mt-2">{categoryDescription}</p>
      )
    }
  </section>

  <section class="mx-auto max-w-7xl px-4 pb-20 md:px-8">
    {
      products && products.length > 0 ? (
        <ul class="grid grid-cols-2 gap-x-6 gap-y-12 md:grid-cols-3 xl:grid-cols-4">
          {products.map((product) => (
            <li>
              <ProductCard
                product={product}
                categorie={categorie!}
                capacityUnit={capacityUnit}
                priceWeekendShortSuffix={priceWeekendShortSuffix}
                priceWeekShortSuffix={priceWeekShortSuffix}
              />
            </li>
          ))}
        </ul>
      ) : (
        <div class="border-border rounded-xl border border-dashed py-16 text-center">
          <p class="text-muted-foreground text-sm">{emptyState}</p>
        </div>
      )
    }
  </section>
</Layout>
