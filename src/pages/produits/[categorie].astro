---
import Layout from "../../layouts/Layout.astro";
import SanityImage from "../../components/SanityImage.astro";
import {
  getAllCategories,
  getCategoryBySlug,
  getPageBySlug,
  getProductsByCategory,
} from "../../lib/sanity";
import { stegaClean } from "@sanity/client/stega";

export async function getStaticPaths() {
  const { data: categories } = await getAllCategories();
  return (categories ?? []).map((cat) => ({
    params: { categorie: cat.slug },
  }));
}

const { categorie } = Astro.params;
const { data: category } = await getCategoryBySlug(categorie!);
const { data: categoryTemplatePage } =
  await getPageBySlug("produits-categorie");

if (!category) {
  return Astro.redirect("/produits");
}

const { data: products } = await getProductsByCategory(category._id);
---

<Layout title={`${category.name} - Fidéloc`}>
  <section class="mx-auto max-w-7xl px-4 py-16 md:px-8">
    <a href="/produits" class="text-brand-accent text-sm hover:underline">
      &larr; {stegaClean(categoryTemplatePage?.labels?.backLabel ?? "")}
    </a>
    <h1
      class="font-heading text-primary mt-4 text-4xl font-bold tracking-tight"
    >
      {category.name}
    </h1>
    {
      category.description && (
        <p class="text-muted-foreground mt-2">{category.description}</p>
      )
    }
  </section>

  <section class="mx-auto max-w-7xl px-4 pb-16 md:px-8">
    {
      products && products.length > 0 ? (
        <ul class="space-y-4">
          {products.map((product) => (
            <li>
              <a
                href={`/produits/${categorie}/${product.slug}`}
                class="border-border hover:border-brand-accent flex items-start gap-4 rounded-lg border p-4 transition-colors"
              >
                {product.images?.asset && (
                  <SanityImage
                    image={product.images}
                    width={120}
                    class="border-border h-16 w-16 shrink-0 rounded-md border object-cover"
                  />
                )}
                <div class="flex flex-1 items-start justify-between gap-4">
                  <div>
                    <p class="font-heading text-primary font-semibold">
                      {product.name}
                    </p>
                    {product.code && (
                      <p class="text-muted-foreground text-xs">
                        {stegaClean(
                          categoryTemplatePage?.labels?.productCodeLabel ?? "",
                        )}{" "}
                        : {product.code}
                      </p>
                    )}
                    {product.dimensions && (
                      <p class="text-muted-foreground mt-1 text-sm">
                        {stegaClean(
                          categoryTemplatePage?.labels?.specDimensionsLabel ??
                            "",
                        )}{" "}
                        : {product.dimensions}
                      </p>
                    )}
                    {product.capacity && (
                      <p class="text-muted-foreground text-sm">
                        {stegaClean(
                          categoryTemplatePage?.labels?.specCapacityLabel ?? "",
                        )}{" "}
                        : {product.capacity}{" "}
                        {stegaClean(
                          categoryTemplatePage?.labels?.capacityUnit ?? "",
                        )}
                      </p>
                    )}
                  </div>
                  <div class="text-right text-sm">
                    <p class="text-primary font-medium">
                      {product.priceWeekend} €{" "}
                      <span class="text-muted-foreground font-normal">
                        {stegaClean(
                          categoryTemplatePage?.labels?.priceWeekendSuffix ??
                            "",
                        )}
                      </span>
                    </p>
                    <p class="text-muted-foreground">
                      {product.priceWeek} €{" "}
                      {stegaClean(
                        categoryTemplatePage?.labels?.priceWeekSuffix ?? "",
                      )}
                    </p>
                  </div>
                </div>
              </a>
            </li>
          ))}
        </ul>
      ) : (
        <p class="text-muted-foreground">
          {stegaClean(categoryTemplatePage?.labels?.emptyState ?? "")}
        </p>
      )
    }
  </section>
</Layout>
