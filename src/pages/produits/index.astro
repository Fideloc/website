---
import Layout from "../../layouts/Layout.astro";
import { getAllCategories } from "../../lib/sanity";

const categories = await getAllCategories();
---

<Layout title="Nos produits — Fidéloc">
  <section class="mx-auto max-w-4xl px-6 py-16">
    <h1 class="font-heading text-primary text-4xl font-bold tracking-tight">
      Nos produits
    </h1>
    <p class="text-muted-foreground mt-2">
      Parcourez nos catégories d'équipements en location.
    </p>
  </section>

  <section class="mx-auto max-w-4xl px-6 pb-16">
    {
      categories && categories.length > 0 ? (
        <ul class="grid gap-6 sm:grid-cols-2 md:grid-cols-3">
          {categories.map((cat: any) => (
            <li>
              <a
                href={`/produits/${cat.slug}`}
                class="border-border hover:border-brand-accent block rounded-lg border p-6 transition-colors"
              >
                <p class="font-heading text-primary text-lg font-semibold">
                  {cat.name}
                </p>
                {cat.description && (
                  <p class="text-muted-foreground mt-2 text-sm">
                    {cat.description}
                  </p>
                )}
              </a>
            </li>
          ))}
        </ul>
      ) : (
        <p class="text-muted-foreground">Aucune catégorie pour le moment.</p>
      )
    }
  </section>
</Layout>
