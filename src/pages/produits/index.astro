---
import Layout from "../../layouts/Layout.astro";
import { getAllCategories, getPageBySlug } from "../../lib/sanity";
import { stegaClean } from "@sanity/client/stega";

const { data: categories } = await getAllCategories();
const { data: page } = await getPageBySlug("produits");
---

<Layout title={page?.title ? `${page.title} - Fidéloc` : ""}>
  <section class="mx-auto max-w-4xl px-6 py-16">
    <h1 class="font-heading text-primary text-4xl font-bold tracking-tight">
      {stegaClean(page?.title ?? "")}
    </h1>
    <p class="text-muted-foreground mt-2">{stegaClean(page?.intro ?? "")}</p>
  </section>

  <section class="mx-auto max-w-4xl px-6 pb-16">
    {
      categories && categories.length > 0 ? (
        <ul class="grid gap-6 sm:grid-cols-2 md:grid-cols-3">
          {categories.map((cat) => (
            <li>
              <a
                href={`/produits/${cat.slug}`}
                class="border-border hover:border-brand-accent block rounded-lg border p-6 transition-colors"
              >
                <p class="font-heading text-primary text-lg font-semibold">
                  {cat.name}
                </p>
                {cat.description && (
                  <p class="text-muted-foreground mt-2 text-sm">
                    {cat.description}
                  </p>
                )}
              </a>
            </li>
          ))}
        </ul>
      ) : (
        <p class="text-muted-foreground">
          {stegaClean(page?.labels?.emptyState ?? "")}
        </p>
      )
    }
  </section>
</Layout>
