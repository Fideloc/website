---
import Layout from "../../layouts/Layout.astro";
import CategoryCard from "../../components/CategoryCard.astro";
import { getAllCategories, getPageBySlug, urlFor } from "../../lib/sanity";
import { stegaClean } from "@sanity/client/stega";

const { data: categories } = await getAllCategories();
const { data: page } = await getPageBySlug("produits");

const categoryCards = (categories ?? [])
  .filter((cat): cat is typeof cat & { name: string; slug: string } =>
    Boolean(cat.name && cat.slug),
  )
  .map((cat) => ({
    name: cat.name,
    slug: cat.slug,
    description: cat.description,
    imageUrl: cat.image?.asset
      ? urlFor(cat.image)
          .width(600)
          .height(450)
          .fit("crop")
          .auto("format")
          .url()
      : null,
  }));
---

<Layout title={page?.title ? `${page.title} - Fideloc` : ""}>
  <section class="mx-auto max-w-7xl px-4 py-14 md:px-8">
    <h1 class="font-heading text-primary text-4xl font-bold tracking-tight">
      {stegaClean(page?.title ?? "")}
    </h1>
    {
      stegaClean(page?.intro ?? "") && (
        <p class="text-muted-foreground mt-2">
          {stegaClean(page?.intro ?? "")}
        </p>
      )
    }

    {
      categoryCards.length > 0 && (
        <div class="mt-10 grid grid-cols-2 gap-6 space-y-8 lg:grid-cols-3 xl:grid-cols-4">
          {categoryCards.map((cat) => (
            <CategoryCard {...cat} />
          ))}
        </div>
      )
    }
  </section>
</Layout>
