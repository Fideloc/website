---
import { Font } from "astro:assets";
import { VisualEditing } from "@sanity/astro/visual-editing";
import "../styles/global.css";
import { getSiteSettings, getAllCategories } from "../lib/sanity";
import Sidebar from "../components/Sidebar.astro";
import MobileHeader from "../components/MobileHeader.astro";
import MobileMenu from "../components/MobileMenu.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
}

const { title = "Fideloc" } = Astro.props;
const { data: settings } = await getSiteSettings();
const { data: categories } = await getAllCategories();
const navLinks = settings?.navigation ?? [];
const footerLinks = settings?.footerLinks ?? [];
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <Font cssVariable="--astro-font-heading" preload />
    <Font cssVariable="--astro-font-body" preload />
    <title>{title}</title>
  </head>
  <body class="bg-background font-body text-foreground">
    <div class="flex min-h-screen">
      <Sidebar
        categories={categories ?? []}
        navLinks={navLinks}
        footerLinks={footerLinks}
        settings={settings}
        currentPath={currentPath}
      />

      <MobileHeader settings={settings} />

      <MobileMenu
        categories={categories ?? []}
        navLinks={navLinks}
        footerLinks={footerLinks}
        settings={settings}
        currentPath={currentPath}
      />

      <div
        class="flex min-h-screen flex-1 flex-col pt-16 lg:ml-[220px] lg:pt-0 xl:ml-[260px]"
      >
        <main class="flex-1">
          <slot />
        </main>

        <Footer
          settings={settings}
          categories={categories ?? []}
          navLinks={navLinks}
          footerLinks={footerLinks}
        />
      </div>
    </div>

    <VisualEditing enabled={true} />

    <script>
      const button = document.getElementById("mobile-menu-button");
      const menu = document.getElementById("mobile-menu");

      const openMenu = () => {
        menu?.classList.remove("opacity-0", "pointer-events-none");
        menu?.classList.add("opacity-100");
        button?.setAttribute("aria-expanded", "true");
        button?.setAttribute("aria-label", "Fermer");
        document.body.style.overflow = "hidden";
      };

      const closeMenu = () => {
        menu?.classList.add("opacity-0", "pointer-events-none");
        menu?.classList.remove("opacity-100");
        button?.setAttribute("aria-expanded", "false");
        button?.setAttribute("aria-label", "Menu");
        document.body.style.overflow = "";
      };

      button?.addEventListener("click", () => {
        if (button.getAttribute("aria-expanded") === "true") {
          closeMenu();
        } else {
          openMenu();
        }
      });
    </script>
  </body>
</html>
